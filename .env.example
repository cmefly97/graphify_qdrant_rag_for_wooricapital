# ===== LLM: HCX-30B-Text (사내 게이트웨이 · OpenAI 호환 · thinking) =====
HCX30_BASE_URL=http://223.130.140.68:8000/v1/chat/completions
HCX30_API_KEY=sk-your-key-here
HCX30_MODEL=hcx-agent-06

# ===== LLM: Qwen 폴백 =====
QWEN_BASE_URL=http://223.130.140.218:8000/v1/chat/completions
QWEN_MODEL=Qwen3.6-35B-A3B

# ===== 임베딩 (Octen · 사내 vLLM) =====
EMBEDDING_BASE_URL=http://223.130.140.218:8002/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=Octen-Embedding-8B

# ===== 인프라 =====
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=woori_auto

# ===== 동작 옵션 =====
# 게이트웨이 미연결(로컬/CI)에서 결정적 폴백 임베딩 사용
ALLOW_OFFLINE_FALLBACK=true
GATEWAY_TIMEOUT=30
GATEWAY_MAX_RETRIES=3
# 답변 최대 토큰(잘림 방지). 더 긴 답변이 필요하면 상향
ANSWER_MAX_TOKENS=2048
