{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "하네스 hooks — 파일 변경 시 자동 검증으로 에러 누적을 차단한다.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/post_edit_validate.py\"", "timeout": 60 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/secret_guard.py\"", "timeout": 30 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/phase_gate.py\"", "timeout": 60 }
        ]
      }
    ]
  }
}
